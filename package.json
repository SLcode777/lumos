{
  "name": "lumos",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "infisical run --env=dev -- next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "infisical run --env=dev -- prisma migrate dev",
    "db:studio": "infisical run --env=dev -- prisma studio",
    "db:reset": "infisical run --env=dev -- prisma migrate reset",
    "test": "infisical run --env=dev -- vitest run",
    "test:watch": "infisical run --env=dev -- vitest",
    "test:ui": "infisical run --env=dev -- vitest --ui",
    "docker:up": "infisical run --env=dev -- docker compose up -d --build",
    "docker:down": "infisical run --env=dev -- docker compose down",
    "docker:wipe": "infisical run --env=dev -- docker compose down -v",
    "docker:logs": "infisical run --env=dev -- docker compose logs -f app"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.0.9"
}