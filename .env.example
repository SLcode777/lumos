# Used by the app service in docker-compose
APP_PORT=3000

# SQLite file path for the application database.
DATABASE_URL=file:./lumos.db

# Optional, tests only. Postgres URL used by integration tests in
# lib/{connections,pool-manager,introspect}.test.ts. Defaults match the
# bundled db-demo container (cd db-demo && docker compose up -d).
TEST_PG_URL=postgresql://demo:demo@localhost:5434/shop

# Better Auth
# Random 32-byte secret used to sign sessions.                       
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of this Lumos instance (no trailing slash).             
BETTER_AUTH_URL=http://localhost:3000

# Registration policy
# How new users can sign up. One of: open | invite-only | closed     
# - open        : anyone can create an account                     
# - invite-only : only with a valid invitation link (default)        
# - closed      : no new sign-ups                                    
# The very first user always passes (instance bootstrap).            
REGISTRATION_MODE=invite-only

# Encryption (user-saved PostgreSQL connection strings)              
# AES-256 key (32 bytes, base64-encoded) used to encrypt connection  
# strings before storing them in the application database.
# Generate with: openssl rand -base64 32                             
#⚠️ Keep this secret. Losing it means losing access to all stored
# credentials. Rotating it requires re-encrypting existing rows.     
ENCRYPTION_KEY=

# Default lifetime for invitation tokens, in days. Optional (default: 7).
INVITATION_TTL_DAYS=7